<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_width} ${base_length} ${base_height}" />
            </geometry>
            <material name="grey" />
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_width} ${base_length} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="1.5" x="${base_width}" y="${base_length}" z="${base_height}"
            o_xyz="0 0 ${base_height/2}" o_rpy="0 0 0" />
    </link>

    <link name="left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}" />
            </geometry>
            <material name="red" />
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        </visual>

        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        </collision>

        <xacro:cylinder_inertia m="0.030" r="${wheel_radius}" h="${wheel_length}" o_xyz="0 0 0"
            o_rpy="0 0 0" />
    </link>

    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}" />
            </geometry>
            <material name="red" />
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
        </collision>
        <xacro:cylinder_inertia m="0.030" r="${wheel_radius}" h="${wheel_length}" o_xyz="0 0 0"
            o_rpy="0 0 0" />
    </link>


    <link name="front_sphere_link"> <!-- caster wheel -->
        <visual>
            <geometry>
                <sphere radius="${sphere_radius}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="red" />
        </visual>

        <collision>
            <geometry>
                <sphere radius="${sphere_radius}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <xacro:sphere_inertia m="0.030" r="${sphere_radius}" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <link name="back_sphere_link"> <!-- caster wheel -->
        <visual>
            <geometry>
                <sphere radius="${sphere_radius}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="red" />
        </visual>

        <collision>
            <geometry>
                <sphere radius="${sphere_radius}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <xacro:sphere_inertia m="0.030" r="${sphere_radius}" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="base_footprint_base_link_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${0.002 + 2 * wheel_radius}" rpy="0 0 0" />
    </joint>

    <joint name="base_link_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="0 ${base_length/2 + wheel_length/2 + 0.015} -${0.002 + wheel_radius}"
            rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_link_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="0 -${base_length/2 + wheel_length/2 + 0.015} -${0.002 + wheel_radius}"
            rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_link_front_sphere_joint" type="fixed">
        <parent link="base_link" />
        <child link="front_sphere_link" />
        <origin xyz="${base_width/2 - 0.04} 0 -${sphere_radius + 0.002}" rpy="0 0 0" />
    </joint>

    <joint name="base_link_back_sphere_joint" type="fixed">
        <parent link="base_link" />
        <child link="back_sphere_link" />
        <origin xyz="-${base_width/2 - 0.04} 0 -${sphere_radius + 0.002}" rpy="0 0 0" />
    </joint>

    <joint name="base_link_rplidar_base_link" type="fixed">
        <parent link="base_link" />
        <child link="rplidar_base_link" />
        <origin xyz="${base_width/4} 0 ${base_height-0.005}" rpy="0 0 0" />
    </joint>

    <joint name="base_link_rplidar" type="fixed">
        <parent link="base_link" />
        <child link="rplidar" />
        <origin xyz="${base_width/4} 0 ${base_height+0.057}" rpy="0 0 0" />
    </joint>

    <joint name="base_link_head_base" type="fixed">
        <parent link="base_link" />
        <child link="head_base" />
        <origin xyz="${base_width/4} 0 ${base_height+0.07}" rpy="0 0 0" />
    </joint>

    <gazebo reference="front_sphere_link">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

    <gazebo reference="back_sphere_link">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>
</robot>